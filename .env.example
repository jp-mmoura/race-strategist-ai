# =============================================================================
# F1 Race Strategist AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the project:
#
#   cp .env.example .env
#
# Variables marked REQUIRED must be set for the application to start.
# Variables marked OPTIONAL fall back to the listed default when absent.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------

# Which LLM backend to use: "google" (Gemini) or "openai" (GPT).
# [OPTIONAL] Default: google
STRATEGY_LLM_PROVIDER=google

# Model name for the selected provider.
#   Google examples : gemini-2.0-flash  |  gemini-1.5-pro
#   OpenAI examples : gpt-4o            |  gpt-4o-mini
# [OPTIONAL] Default: gemini-2.0-flash
STRATEGY_LLM_MODEL=gemini-2.0-flash

# Sampling temperature for strategy generation (0.0 = deterministic, 1.0 = creative).
# [OPTIONAL] Default: 0.3
STRATEGY_LLM_TEMPERATURE=0.3


# -----------------------------------------------------------------------------
# API Keys — LLM
# -----------------------------------------------------------------------------

# Google Gemini API key.
# Required when STRATEGY_LLM_PROVIDER=google (or as fallback).
# Obtain at: https://aistudio.google.com/app/apikey
# [REQUIRED if using Google] No default.
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# OpenAI API key.
# Required when STRATEGY_LLM_PROVIDER=openai.
# Obtain at: https://platform.openai.com/api-keys
# [REQUIRED if using OpenAI] No default.
OPENAI_API_KEY=your_openai_api_key_here


# -----------------------------------------------------------------------------
# FastF1 — Data Cache
# -----------------------------------------------------------------------------

# Directory where FastF1 stores downloaded session data.
# Persisting this directory avoids re-downloading sessions on each run.
# Accepts absolute or relative paths (relative = resolved from project root).
# [OPTIONAL] Default: <project_root>/data/fastf1_cache
FASTF1_CACHE_DIR=data/fastf1_cache

# Maximum seconds to wait for a FastF1 session.load() call before raising
# TimeoutError.  Increase on slow connections; decrease for faster failure.
# [OPTIONAL] Default: 120
FASTF1_TIMEOUT_SECONDS=120


# -----------------------------------------------------------------------------
# RAG — ChromaDB Vector Store
# -----------------------------------------------------------------------------

# Directory where ChromaDB persists embeddings and index files.
# Must be populated by running `python -m rag.ingestor` before first use.
# Accepts absolute or relative paths (relative = resolved from project root).
# [OPTIONAL] Default: <project_root>/data/chroma_db
CHROMA_PERSIST_DIRECTORY=data/chroma_db


# -----------------------------------------------------------------------------
# LangChain / LangSmith — Observability & Tracing (all optional)
# -----------------------------------------------------------------------------

# LangSmith API key — enables trace logging for LangGraph workflow runs.
# Obtain at: https://smith.langchain.com/
# [OPTIONAL] Tracing is disabled when this key is absent.
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# Set to "true" to activate LangSmith tracing.
# Has no effect unless LANGCHAIN_API_KEY is also set.
# [OPTIONAL] Default: false
LANGCHAIN_TRACING_V2=false

# LangSmith project name shown in the UI dashboard.
# [OPTIONAL] Default: default
LANGCHAIN_PROJECT=race-strategist-ai

# LangSmith ingestion endpoint.
# Override only if using a self-hosted LangSmith instance.
# [OPTIONAL] Default: https://api.smith.langchain.com
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
